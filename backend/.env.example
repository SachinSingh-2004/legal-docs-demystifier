# ============================================================
# Legal Docs Demystifier — Environment Variables Template
# Copy this file to .env and fill in your credentials.
# ============================================================

# ──────────────────────────────────────────────
# AI PROVIDERS
# ──────────────────────────────────────────────

# Google Gemini API Key (PRIMARY - get from https://aistudio.google.com/)
GEMINI_API_KEY=yAQ.Ab8RN6LqM-aGvN3bbqWnFUnzM9piofJi9J6pxmZhqzeGLbi0rQour_gemini_api_key_here

# Gemini model to use (defaults to gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-pro

# OpenAI API Key (FALLBACK - get from https://platform.openai.com/)
OPENAI_API_KEY=your_openai_apiAQ.Ab8RN6JY3OgWhFXNmGx-i4NHXLxuJcHvfisNoSiFAiwF4R3xLQ

# OpenAI model to use (defaults to gpt-4o)
OPENAI_MODEL=gpt-4o

# Which provider to attempt first: 'gemini' or 'openai'
PRIMARY_AI_PROVIDER=gemini


# ──────────────────────────────────────────────
# PINECONE VECTOR DATABASE
# ──────────────────────────────────────────────

# Pinecone API Key (get from https://www.pinecone.io/)
PINECONE_API_KEY=your_pinecone_api_key_herepcsk_DXPBx_ShmaXNACf6hXqKnCVj2TgVJhkAwAZNuLUUaEXTpGkBNraWwLwvhphm7oXoTUnDz

# Pinecone Index Name (must have dimension=768 for text-embedding-004)
PINECONE_INDEX=legal-docs-index


# ──────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────

# MongoDB URI (local or MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/legal-docs-demystifier


# ──────────────────────────────────────────────
# AUTHENTICATION
# ──────────────────────────────────────────────

# JWT Access Token Secret (change this to a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_in_production_at_least_64_chars

# JWT Refresh Token Secret (use a different secret than access token)
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_at_least_64_chars

# Access token expiry
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token expiry
JWT_REFRESH_EXPIRES_IN=7d


# ──────────────────────────────────────────────
# SERVER CONFIGURATION
# ──────────────────────────────────────────────

# Server Port
PORT=3001

# Node environment
NODE_ENV=development

# Max file upload size in MB
MAX_FILE_SIZE_MB=10

# CORS Origin (frontend URL)
FRONTEND_URL=http://localhost:5173

# Log Level (error, warn, info, http, debug)
LOG_LEVEL=info
